<Window x:Class="VeraCom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeraCom"
        mc:Ignorable="d"
        Title="VeraComTool" Height="800" Width="1000" Background="#3F3F3F">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menü -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid 1 -->
            <RowDefinition Height="*"/>
            <!-- DataGrid 2 -->
        </Grid.RowDefinitions>

        <!-- Menü -->
        <Menu Grid.Row="0">
            <MenuItem Header="Datei">
                <MenuItem Header="Öffnen" Click="DateiOeffnen_Click"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Beenden_Click"/>
            </MenuItem>
            <MenuItem Header="Einstellungen"/>
            <MenuItem Header="Hilfe"/>
        </Menu>

        <ToolBar Grid.Row="1">
            <!-- Start / Stop Buttons -->
            <Button Content="Start" Name="BtnStart" IsEnabled="False" Width="60" Click="Start_Click"/>
            <Button Content="Stop" Name="BtnStop" IsEnabled="False" Width="60" Click="Stop_Click"/>

            <Separator/>

            <!-- Datenbankpfad anzeigen -->
            <TextBox Name="TxtDatabasePath"
             Width="400"
             IsReadOnly="True"
             Margin="5,0,0,0"
             VerticalAlignment="Center"/>
        </ToolBar>

        <!-- Erstes DataGrid -->
        <DataGrid ItemsSource="{Binding Messages}"
          AutoGenerateColumns="False"
          Grid.Row="2"
          Margin="5">

            <DataGrid.Columns>
                <DataGridTextColumn Header="CAN ID" Binding="{Binding CanID}" Width="*" />
                <DataGridTextColumn Header="DLC" Binding="{Binding DLC}" Width="*" />
                <DataGridTextColumn Header="Cycle (ms)" Binding="{Binding CycleTimeMs}" Width="*" />
                <DataGridTextColumn Header="Payload" Binding="{Binding PayloadString}" Width="2*" />
                <DataGridTextColumn Header="Tx Count" Binding="{Binding TxFrameCounter}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Zweites DataGrid -->
        <DataGrid Grid.Row="3"
          ItemsSource="{Binding ReceivedMessages}"
          AutoGenerateColumns="False"
          Margin="5">

            <DataGrid.Columns>
                <DataGridTextColumn Header="CAN ID" Binding="{Binding CanID}" Width="*" />
                <DataGridTextColumn Header="DLC" Binding="{Binding DLC}" Width="*" />
                <DataGridTextColumn Header="Payload" Binding="{Binding PayloadString}" Width="2*" />
                <DataGridTextColumn Header="Cycle (ms)" Binding="{Binding RxCycleTime}" Width="*" />
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
    
</Window>
