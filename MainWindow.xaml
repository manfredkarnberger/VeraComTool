<Window x:Class="VeraCom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VeraCom"
        mc:Ignorable="d"
        Title="VeraComTool" Height="800" Width="1000" Background="#3F3F3F">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Menü -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid 1 -->
            <RowDefinition Height="*"/>
            <!-- DataGrid 2 -->
        </Grid.RowDefinitions>

        <!-- Menü -->
        <Menu Grid.Row="0">
            <MenuItem Header="Datei">
                <MenuItem Header="Öffnen" Click="DateiOeffnen_Click"/>
                <Separator/>
                <MenuItem Header="Beenden" Click="Beenden_Click"/>
            </MenuItem>
            <MenuItem Header="Einstellungen"/>
            <MenuItem Header="Hilfe"/>
        </Menu>

        <ToolBar Grid.Row="1">

            <!-- Start / Stop Buttons -->
            <Button Content="Start" Name="BtnStart" IsEnabled="False" Width="60" Click="Start_Click"/>
            <Button Content="Stop" Name="BtnStop" IsEnabled="False" Width="60" Click="Stop_Click"/>

            <Separator/>

            <!-- Datenbankpfad anzeigen -->
            <TextBox Name="TxtDatabasePath"
             Width="400"
             IsReadOnly="True"
             Margin="5,0,0,0"
             VerticalAlignment="Center"/>
        </ToolBar>

        <!-- Erstes DataGrid -->
        <DataGrid x:Name="DataGridSentMessages" 
            Grid.Row="2" 
            ItemsSource="{Binding Messages}" 
            AutoGenerateColumns="True"
            Margin="5"/>

        <!-- Zweites DataGrid -->
        <DataGrid x:Name="DataGridReceivedMessages" 
            Grid.Row="3" 
            ItemsSource="{Binding Messages}" 
            AutoGenerateColumns="True"
            Margin="5"/>

    </Grid>
    
</Window>
